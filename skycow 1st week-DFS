#DFS 음료수 얼음

M,N = map(int, input().split())

table = [] 

for i in range(M):
    table.append(list(map(int,input())))
    
def ice (x,y):
    if x<0 or x>=M or y<0 or y>=N:
        return False 
        
    if table [x][y]==0: 
        table[x][y]=1  
        ice(x,y-1) 
        ice(x,y+1) 
        ice(x-1,y) 
        ice(x+1,y) 
        return True 
    
    return False
    
result=0 
for i in range(M): 
    for j in range(N):
        if ice(i,j):
            result+=1
print(result)
