n = int(input()) # 피보나치 : 0과 1로 시작, 0번째 부터 바로 앞 두 피보나치의 수의 합이 다음 수 (0 1 1 2 3 5 8..) 식으로 쓰면, Fn = Fn - 1 + Fn - 2(n>=2)

# n을 입력 받음, n은 90보다 작거나 같은 자연수
dp = [-1] * (n + 1) 

def fib(x):
    # 기본값(기저 사례)
    if x == 0:
        return 0
    if x == 1:
        return 1

    # 이미 계산한 값이면 바로 반환
    if dp[x] != -1:
        return dp[x]

    # 아직 계산하지 않았다면 저장 후 반환
    dp[x] = fib(x - 1) + fib(x - 2)
    return dp[x]

print(fib(n))
